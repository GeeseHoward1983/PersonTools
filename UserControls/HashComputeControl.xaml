<UserControl x:Class="PersonalTools.UserControls.HashComputeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PersonalTools.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200" Margin="10" AllowDrop="True" Drop="HashTab_Drop" PreviewDragOver="Grid_PreviewDragOver">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- 6 种定长哈希（MD5/SHA1/SHA224/SHA256/SHA384/SHA512）：数据模板渲染，避免逐个命名控件 -->
            <ItemsControl x:Name="HashItemsControl" Margin="0,0,0,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <GroupBox Header="{Binding Header}" Margin="0,0,10,10" MinWidth="520">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="{Binding InputPrompt}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalAlignment="Center" Width="400"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                    <!-- 同面板内两个单选自动互斥；只把 Hex 双向绑定到 IsHexMode -->
                                    <RadioButton Content="普通字符串" IsChecked="True" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton Content="Hex字符串" IsChecked="{Binding IsHexMode, Mode=TwoWay}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Button Content="{Binding CalcButtonText}" Click="HashCompute_Click" Padding="10,3" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <Button Content="清空" Click="HashClear_Click" Padding="10,3" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ResultPrompt}" Margin="0,0,5,0" VerticalAlignment="Top"/>
                                    <Label Grid.Column="1" Content="{Binding Result}" Padding="5"
                                           Background="White" BorderBrush="Gray" BorderThickness="1"
                                           HorizontalContentAlignment="Left"/>
                                </Grid>
                            </Grid>
                        </GroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- SHA3计算 - 独占一行 -->
            <GroupBox Header="SHA3计算" Margin="0,0,0,10" MinWidth="600">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="输入要计算SHA3的值：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Name="SHA3InputTextBox" Height="25" VerticalAlignment="Center" Width="400"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Name="SHA3StringInputRadio" Content="普通字符串" GroupName="SHA3InputType" IsChecked="True" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <RadioButton Name="SHA3HexInputRadio" Content="Hex字符串" GroupName="SHA3InputType" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <ComboBox Name="SHA3AlgorithmComboBox" Width="200" Margin="0,0,10,0" VerticalAlignment="Center" DisplayMemberPath="Name"/>
                        <Button Name="CalculateSHA3Button" Content="计算SHA3" Click="CalculateSHA3_Click" Padding="10,3" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <Button Name="ClearSHA3Button" Content="清空" Click="ClearSHA3_Click" Padding="10,3" Margin="0,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SHA3结果：" Margin="0,0,5,0" VerticalAlignment="Top"/>
                        <Label Grid.Column="1" Name="SHA3ResultLabel" Content="等待计算..." Padding="5" 
                               Background="White" BorderBrush="Gray" BorderThickness="1" 
                               HorizontalContentAlignment="Left"/>
                    </Grid>
                </Grid>
            </GroupBox>

            <TextBlock Text="将文件拖放到此标签页以计算哈希值" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       FontSize="14" 
                       Foreground="Gray" 
                       Margin="0,20,0,0" 
                       Name="FileDropHint"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>