<UserControl x:Class="PersonalTools.UserControls.ELFGotControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PersonalTools.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <GroupBox x:Name="GotGroupBox" Header="GOT 表" Margin="5">
        <DataGrid Name="ELFGotDataGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="序号" Binding="{Binding Number}" Width="*"/>
                <DataGridTextColumn Header="GOT地址" Binding="{Binding Offset}" Width="2*"/>
                <DataGridTextColumn Header="存储值" Binding="{Binding Value}" Width="2*"/>
                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="*"/>
                <DataGridTextColumn Header="符号" Binding="{Binding Symbol}" Width="2*"/>
                <DataGridTextColumn Header="节名称" Binding="{Binding SectionName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </GroupBox>
</UserControl>
