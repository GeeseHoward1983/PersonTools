<UserControl x:Class="PersonalTools.UserControls.MarkdownToWordControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PersonalTools.UserControls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             AllowDrop="True" Drop="OnDrop" PreviewDragOver="OnPreviewDragOver"
             Loaded="OnLoaded" Unloaded="OnUnloaded">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具条 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="打开 md" Click="OpenFile_Click" Padding="12,4" Margin="0,0,6,0"/>
            <Button Content="导出 Word" Click="Export_Click" Padding="12,4" Margin="0,0,6,0"/>
            <Button Content="重置样式" Click="ResetStyles_Click" Padding="12,4" Margin="0,0,16,0"/>
            <CheckBox x:Name="GenerateTocCheckBox" Content="生成目录" VerticalAlignment="Center" Click="GenerateToc_Click"/>
        </StackPanel>

        <!-- 导出样式设置 -->
        <Expander Grid.Row="1" Header="导出样式设置" Margin="0,0,0,6">
            <DataGrid x:Name="StyleGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserReorderColumns="False" HeadersVisibility="Column" MaxHeight="230" Margin="0,4,0,0"
                      CellEditEnding="StyleGrid_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="内容类型" Binding="{Binding DisplayName}" IsReadOnly="True" Width="90"/>
                    <DataGridComboBoxColumn x:Name="ChineseFontColumn" Header="中文字体" SelectedItemBinding="{Binding ChineseFont}" Width="120"/>
                    <DataGridComboBoxColumn x:Name="WesternFontColumn" Header="西文字体" SelectedItemBinding="{Binding WesternFont}" Width="150"/>
                    <DataGridComboBoxColumn x:Name="FontSizeColumn" Header="字号" SelectedItemBinding="{Binding FontSizeName}" Width="80"/>
                    <DataGridCheckBoxColumn Header="加粗" Binding="{Binding Bold}" Width="50"/>
                    <DataGridCheckBoxColumn Header="下划线" Binding="{Binding Underline}" Width="60"/>
                    <DataGridTextColumn Header="首行缩进(字)" Binding="{Binding FirstLineIndentChars}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <!-- 左编辑 / 右预览 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Markdown 源（可编辑）">
                <TextBox x:Name="Editor" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="13" TextChanged="Editor_TextChanged"/>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <GroupBox Grid.Column="2" Header="预览">
                <wv2:WebView2 x:Name="Preview"/>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
