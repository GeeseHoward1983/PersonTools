<UserControl x:Class="PersonalTools.UserControls.PEAnalyzerHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PersonalTools.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             AllowDrop="True" Drop="Host_Drop" PreviewDragOver="Host_PreviewDragOver">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 菜单栏 -->
        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="打开" Click="OpenFile_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <!-- 每个文件一个 tab -->
        <Grid Grid.Row="1">
            <TabControl x:Name="FileTabs" Margin="2"/>
            <TextBlock x:Name="EmptyHint"
                       Text="拖入或打开 PE 文件 (*.exe / *.dll / *.sys)"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="14" IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</UserControl>
